<Page x:Class="PCClub.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PCClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authorization">

    <Grid>
        <Border Background="#7FFFFFFF" Width="500" Height="400" CornerRadius="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="93*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="13*"/>
                    <ColumnDefinition Width="473*"/>
                    <ColumnDefinition Width="13*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Margin="0,50,0,0" Grid.Row="1">
                    <Label Content="Войти" HorizontalAlignment="Center" FontSize="30" FontWeight="ExtraBold"/>
                    <TextBlock Text="Логин" FontSize="20" Margin="0,30,0,0" FontWeight="Medium"/>
                    <Border CornerRadius="10" 
                            Background="White" 
                            Height="40">
                            <TextBox Name="LoginTB" 
                                     Background="{x:Null}"
                                     BorderThickness="0"
                                     Padding="8"
                                     FontSize="15"/>
                    </Border>
                    <TextBlock Text="Пароль" FontSize="20" Margin="0,30,0,0" FontWeight="Medium"/>
                    <Border CornerRadius="10"
                            Background="White"
                            BorderThickness="0"
                            Height="40">
                        <PasswordBox Background="{x:Null}"
                                     Name="PasswordPB"
                                     BorderThickness="0"
                                     Padding="8"
                                     FontSize="15"/>
                    </Border>
                    <Button Name="AuthorizationBT" 
                            FontSize="30" 
                            FontWeight="Bold" 
                            Margin="0,30,0,0"
                            Height="50"
                            Content="Войти"
                            Foreground="White" 
                            Click="AuthorizationBT_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10"
                                        Background="#005494">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
