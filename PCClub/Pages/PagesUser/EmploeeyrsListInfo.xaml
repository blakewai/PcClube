<Page x:Class="PCClub.Pages.PagesUser.EmploeeyrsListInfo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PCClub.Pages.PagesUser"
      mc:Ignorable="d" 
      d:DesignHeight="368" d:DesignWidth="670"
      Title="EmploeeyrsListInfo">

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="18*"/>
                <RowDefinition Height="37*"/>
                <RowDefinition Height="313*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="13*"/>
                <ColumnDefinition Width="107*"/>
                <ColumnDefinition Width="13*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Row="1" 
        Grid.Column="1" 
        VerticalAlignment="Center" 
        HorizontalAlignment="Left" 
        Width="100" 
        Height="30"
        Foreground="White"
        Name="SearchBT" Margin="430,0,0,0" Click="SearchBT_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#46AFFF"
                    CornerRadius="5">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Поиск" FontSize="17" Margin="0,0,5,0"/>
                                    <Image Source="/Logic/SavePhoto/free-icon-magnifying-glass-151773.png"  Width="20" Height="20" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Border Grid.Row="1" 
        Grid.Column="1" 
        Width="400" 
        Height="30" 
        VerticalAlignment="Center" 
        HorizontalAlignment="Left"
        CornerRadius="5"
        Background="White"
        BorderThickness="0">
                <TextBox Background="Transparent"
             BorderThickness="0"
             Padding="5"
             Name="SearchTB"/>
            </Border>
            <DataGrid AutoGenerateColumns="False" Grid.Column="1" Grid.Row="2" Name="DGInfo">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <Button Name="EditBT" Content="Редактировать" Click="EditBT_Click"/>
                        <Button Name="DeleteBT" Content="Удалить" Click="DeleteBT_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                            Binding="{Binding Id}"
                            IsReadOnly="True"/>
                    <DataGridTextColumn Header="Фамилия"
                            Binding="{Binding LastName}"/>
                    <DataGridTextColumn Header="Имя"
                            Binding="{Binding FirstName}"/>
                    <DataGridTextColumn Header="Отчество"
                            Binding="{Binding SureName}"/>
                    <DataGridTextColumn Header="Зарплата"
                            Binding="{Binding Salary}"/>
                    <DataGridTextColumn Header="Почта"
                            Binding="{Binding Email}"/>
                    <DataGridTextColumn Header="Телефон"
                            Binding="{Binding Phone}"/>
                    <DataGridTextColumn Header="Дата рождения"
                            Binding="{Binding Birthday}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
