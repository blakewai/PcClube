<Page x:Class="PCClub.Pages.PagesUser.ProfileUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PCClub.Pages.PagesUser"
      mc:Ignorable="d" 
      d:DesignHeight="368" d:DesignWidth="670"
      Title="ProfileUser">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="239*"/>
            <ColumnDefinition Width="561*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="51*"/>
            <RowDefinition Height="133*"/>
        </Grid.RowDefinitions>
        <Image Margin="40,0,40,248" Grid.RowSpan="2"/>

        <Border Grid.Column="1"
                CornerRadius="15"
                Background="#46AFFF"
                Width="150" 
                Height="50"
                Margin="0,10,10,0"
                VerticalAlignment="Top" 
                HorizontalAlignment="Right">
            <Button Background="{x:Null}" 
                    Content="Выйти" 
                    FontSize="25" 
                    BorderThickness="0" 
                    Foreground="White"
                    Click="Button_Click"/>
        </Border>
        <StackPanel Grid.Row="1" Margin="0,0,10,0" HorizontalAlignment="Center" FlowDirection="RightToLeft" >
            <Label Content="Имя" FontSize="18"/>
            <Label Content="Фамилия" FontSize="18" Margin="0,8"/>
            <Label Content="Отчество" FontSize="18"/>
            <Label Content="Дата рождения" FontSize="18" Margin="0,8"/>
            <Label Content="Почта" FontSize="18"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1">
            <Border CornerRadius="7" 
                    Background="White" 
                    Height="35">
                <TextBox Name="FirstNameTB"
                         IsEnabled="False"
                         Background="{x:Null}"
                         BorderThickness="0"
                         Padding="8"
                         FontSize="15"/>
            </Border>
            <Border CornerRadius="7"
                    Background="White"
                    Height="35"
                    Margin="0,8">
                <TextBox Name="LastNameTB"
                         Padding="8"
                         IsEnabled="False"
                         Background="{x:Null}"
                         BorderThickness="0"
                         FontSize="15"/>
            </Border>
            <Border Background="White"
                    CornerRadius="7"
                    Height="35">
                <TextBox Name="SureNameTB"
                         Background="{x:Null}"
                         IsEnabled="False"
                         Padding="8"
                         BorderThickness="0"
                         FontSize="15"/>
            </Border>
            <Border Background="White"
                    CornerRadius="7"
                    Height="35"
                    Margin="0,8">
                <DatePicker Name="BirthDayDP"
                            Padding="6"
                            IsEnabled="False"
                            Background="{x:Null}"
                            BorderThickness="0"
                            FontSize="15"/>
            </Border>
            <Border Background="White"
                    CornerRadius="7"
                    Height="35">
                <TextBox Name="EmailTB"
                         Background="{x:Null}"
                         IsEnabled="False"
                         Padding="8"
                         BorderThickness="0"
                         FontSize="15"/>
            </Border>
            <Border Height="50" 
                    Width="220"
                    Background="#005494"
                    HorizontalAlignment="Right"
                    CornerRadius="10"
                    Margin="10">
                <Button Content="Изменить"
                        Foreground="White"
                        Background="{x:Null}"
                        FontSize="20"
                        FontWeight="ExtraBold"
                        BorderThickness="0" Click="Button_Edit"/>
            </Border>

        </StackPanel>
    </Grid>
</Page>
