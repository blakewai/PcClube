<Page x:Class="PCClub.Pages.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PCClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profile">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="0,50,0,0" Orientation="Horizontal">
                <Border CornerRadius="21,21,0,0" Width="100" Background="White" Name="Collor_Profile" BorderThickness="0">
                    <Button Background="{x:Null}" Content="Профиль" FontSize="18" Name="ProfileBT" BorderThickness="0" Click="ProfileBT_Click"/>
                </Border>
                <Border CornerRadius="21,21,0,0" Width="100" Background="White" Name="Collor_Employee" BorderThickness="0">
                    <Button Background="{x:Null}" Content="Работники" FontSize="18" Name="EmployeeBT" BorderThickness="0" Click="EmployeeBT_Click"/>
                </Border>
                <Border CornerRadius="21,21,0,0" Width="100" Background="White" Name="Collor_Data" BorderThickness="0">
                    <Button Background="{x:Null}" Content="Данные" FontSize="18" Name="DataBT" BorderThickness="0" Click="DataBT_Click"/>
                </Border>
                <Border CornerRadius="21,21,0,0" Width="100" Background="White" Name="Collor_Tariff" BorderThickness="0">
                    <Button Background="{x:Null}" Content="Тариф" FontSize="18" Name="TariffBT" BorderThickness="0" Click="TariffBT_Click"/>
                </Border>
                <Border CornerRadius="21,21,0,0" Width="147" Background="White" Name="Collor_Accessories" BorderThickness="0">
                    <Button Background="{x:Null}" Content="Комплектующие" FontSize="18" Name="AccessoriesBT" BorderThickness="0" Click="AccessoriesBT_Click"/>
                </Border>
                <Border CornerRadius="21,21,0,0" Width="121" Background="White" Name="Collor_Manager" BorderThickness="0">
                    <Button Background="{x:Null}" Content="Менеджеры" FontSize="18" Name="ManagerBT" BorderThickness="0" Click="ManagerBT_Click"/>
                </Border>
            </StackPanel>
            <Border Background="#7FFFFFFF"
                    Height="368"
                    Width="670"
                    CornerRadius="0,0,20,20" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid>
                    <Frame x:Name="FrameUser"/>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Page>